# ========== Ботопогодка — змінні середовища ==========
# Скопіюй у .env і заповни значення.
# На Vercel: Settings → Environment Variables — додай ті самі пари.

# ----- Обов'язкові -----
TELEGRAM_TOKEN=
OPENWEATHER_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- AI (OpenAI для «Що вдягнути» та «Пояснення») -----
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=

# ----- Опційно (захист cron) -----
CRON_SECRET=
