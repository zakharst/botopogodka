# ========== Ботопогодка — змінні середовища ==========
# Скопіюй у .env і заповни значення.
# На Vercel: Settings → Environment Variables — додай ті самі пари.

# ----- Обов'язкові -----
TELEGRAM_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Погода (краще мати обидва — план Б) -----
# WeatherAPI.com — основний, безкоштовно 100 000 запитів/місяць
WEATHERAPI_API_KEY=
# OpenWeather — план Б при помилці або вичерпанні ліміту WeatherAPI
OPENWEATHER_API_KEY=

# ----- AI (OpenAI для «Що вдягнути» та «Пояснення») -----
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=

# ----- Опційно (захист cron) -----
CRON_SECRET=

# ----- Дашборд статистики (/dashboard на Vercel) -----
# Пароль у формі; у браузері передається заголовком X-Dashboard-Key (див. api/dashboard.js)
DASHBOARD_PASSWORD=
